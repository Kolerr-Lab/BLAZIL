# Aeron C submodule placeholder
#
# This directory is the mount point for the real-logic/aeron git submodule.
# It must be initialised before building blazil-aeron-sys with the C library:
#
#   git submodule add https://github.com/real-logic/aeron.git core/aeron-sys/aeron
#   git submodule update --init --recursive
#
# Pin to a stable tag after initialisation:
#
#   cd core/aeron-sys/aeron
#   git checkout 1.44.1
#   cd ../../..
#   git add core/aeron-sys/aeron
#   git commit -m "chore: pin aeron submodule to 1.44.1"
#
# The build.rs gracefully handles the absent submodule for `cargo check` / clippy.
