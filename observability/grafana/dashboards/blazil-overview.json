{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Blazil platform-wide overview: transactions, latency, ring buffer, gRPC",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Transaction Rate (all services)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service) (rate(blazil_transactions_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Transaction Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service, status) (rate(blazil_transactions_total{status!=\"success\",status!=\"settled\",status!=\"cleared\",service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }}/{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Transaction P99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(blazil_transaction_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p99 {{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Ring Buffer Utilization",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.6, "color": "yellow" },
              { "value": 0.8, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "blazil_ring_buffer_utilization_ratio{instance=\"engine\"}",
          "legendFormat": "Ring buffer",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Engine P99 Pipeline Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ns" }
      },
      "targets": [
        {
          "expr": "blazil_pipeline_p99_ns",
          "legendFormat": "p99 latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "gRPC Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (service, method) (rate(blazil_grpc_requests_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }} {{ method }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "gRPC Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (service, code) (rate(blazil_grpc_requests_total{code!=\"OK\",service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }}/{{ code }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Deposits by Chain",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (chain, status) (rate(blazil_deposits_total[5m]))",
          "legendFormat": "{{ chain }}/{{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Withdrawals by Chain",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (chain, status) (rate(blazil_withdrawals_total[5m]))",
          "legendFormat": "{{ chain }}/{{ status }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["blazil", "overview"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(blazil_transactions_total, service)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(blazil_transactions_total, service)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Blazil Overview",
  "uid": "blazil-overview",
  "version": 1
}
