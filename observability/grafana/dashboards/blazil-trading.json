{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Blazil trading service: order placement rate, trade rate, order book depth, settlement latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Trade Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(blazil_transactions_total{service=\"trading\",status=\"matched\"}[5m]))",
          "legendFormat": "Trades / sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Order Book Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "blazil_orderbook_depth{instrument=~\"$instrument\",side=\"bid\"}",
          "legendFormat": "Bid {{ instrument }}",
          "refId": "A"
        },
        {
          "expr": "blazil_orderbook_depth{instrument=~\"$instrument\",side=\"ask\"}",
          "legendFormat": "Ask {{ instrument }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Order Placement Latency P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(blazil_transaction_duration_seconds_bucket{service=\"trading\"}[5m])))",
          "legendFormat": "p99 latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "gRPC Trading Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (method, code) (rate(blazil_grpc_requests_total{service=\"trading\"}[5m]))",
          "legendFormat": "{{ method }}/{{ code }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["blazil", "trading"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(blazil_orderbook_depth, instrument)",
        "hide": 0,
        "includeAll": true,
        "label": "Instrument",
        "multi": true,
        "name": "instrument",
        "options": [],
        "query": "label_values(blazil_orderbook_depth, instrument)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Blazil Trading",
  "uid": "blazil-trading",
  "version": 1
}
