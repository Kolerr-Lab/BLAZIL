{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Blazil platform-wide overview: pipeline throughput, latency, ring buffer",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Committed TPS (per node)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_pipeline_events_committed_total[1m])",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Published vs Committed (backpressure)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_pipeline_events_published_total[1m])",
          "legendFormat": "published {{ node }}",
          "refId": "A"
        },
        {
          "expr": "rate(blazil_pipeline_events_committed_total[1m])",
          "legendFormat": "committed {{ node }}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rejected Event Rate (per node)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_pipeline_events_rejected_total[1m])",
          "legendFormat": "rejected {{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Ring Buffer Utilization",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.6, "color": "yellow" },
              { "value": 0.8, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "blazil_ring_buffer_utilization_ratio",
          "legendFormat": "{{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "P99 Pipeline Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ns" }
      },
      "targets": [
        {
          "expr": "blazil_pipeline_p99_ns",
          "legendFormat": "p99 {{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Avg Pipeline Latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "ns" }
      },
      "targets": [
        {
          "expr": "blazil_pipeline_avg_latency_ns",
          "legendFormat": "avg {{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cross-Shard Transactions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_cross_shard_total[1m])",
          "legendFormat": "cross-shard {{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Payments: Concurrency Limit Reached",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_payments_concurrency_limit_reached_total[1m])",
          "legendFormat": "limit reached {{ node }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Payments: Stream Responses Dropped",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(blazil_payments_stream_responses_dropped_total[1m])",
          "legendFormat": "dropped {{ node }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["blazil", "overview"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(blazil_pipeline_events_committed_total, node)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "options": [],
        "query": "label_values(blazil_pipeline_events_committed_total, node)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Blazil Overview",
  "uid": "blazil-overview",
  "version": 3
}
