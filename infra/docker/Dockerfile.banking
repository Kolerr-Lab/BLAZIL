# Blazil banking service — Go multi-stage build
FROM golang:1.25.10-alpine AS builder
WORKDIR /app
COPY . .
WORKDIR /app/services/banking
ENV GOWORK=off
RUN go mod download && go build -o /banking .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates \
    && addgroup -S blazil \
    && adduser -S blazil -G blazil
COPY --from=builder /banking /usr/local/bin/banking
USER blazil
EXPOSE 50052 9092
CMD ["banking"]
