# Blazil gateway service — Go multi-stage build
FROM golang:1.25.10-alpine AS builder
WORKDIR /app
COPY . .
WORKDIR /app/services/gateway
ENV GOWORK=off
RUN go mod download && go build -o /gateway ./cmd/...

FROM alpine:3.19
RUN apk add --no-cache ca-certificates \
    && addgroup -S blazil \
    && adduser -S blazil -G blazil
COPY --from=builder /gateway /usr/local/bin/gateway
USER blazil
EXPOSE 50050 8080 9090
CMD ["gateway"]
