# Blazil trading service — Go multi-stage build
FROM golang:1.25.8-alpine AS builder
WORKDIR /app
COPY . .
WORKDIR /app/services/trading
ENV GOWORK=off
RUN go mod download && go build -o /trading .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates \
    && addgroup -S blazil \
    && adduser -S blazil -G blazil
COPY --from=builder /trading /usr/local/bin/trading
USER blazil
EXPOSE 50053 9093
CMD ["trading"]
