# Blazil crypto service — Go multi-stage build
FROM golang:1.26.3-alpine AS builder
WORKDIR /app
COPY . .
WORKDIR /app/services/crypto
ENV GOWORK=off
RUN go mod download && go build -o /crypto .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates \
    && addgroup -S blazil \
    && adduser -S blazil -G blazil
COPY --from=builder /crypto /usr/local/bin/crypto
USER blazil
EXPOSE 50054 9094
CMD ["crypto"]
