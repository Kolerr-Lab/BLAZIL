[blazil_nodes]
# Replace with real IPs from: terraform output node_public_ips
node-1 ansible_host=<NODE_1_PUBLIC_IP> blazil_node_id=node-1 blazil_shard_id=0
node-2 ansible_host=<NODE_2_PUBLIC_IP> blazil_node_id=node-2 blazil_shard_id=1
node-3 ansible_host=<NODE_3_PUBLIC_IP> blazil_node_id=node-3 blazil_shard_id=2

[blazil_nodes:vars]
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3

[monitor]
# node-1 also hosts Prometheus + Grafana
node-1

[monitor:vars]
ansible_user=root
ansible_ssh_private_key_file=~/.ssh/id_ed25519
