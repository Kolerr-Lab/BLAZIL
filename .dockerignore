# Rust build artifacts — can be several GB, never needed inside Docker
target/

# Git history
.git/

# Aeron C submodule — large C++ source tree, excluded for most images.
# Dockerfile.engine uses io-uring only (no aeron feature) → safe to exclude.
# Dockerfile.inference NEEDS this submodule; it has its own
# Dockerfile.inference.dockerignore that does NOT exclude this path.
core/aeron-sys/aeron/

# Local dev / IDE
.env
.env.*
*.env
.vscode/
.idea/
*.iml

# Benchmark / test artifacts
bench/target/
docs/benchmark-screenshots/
docs/benchmark-results/

# CI
.github/

# Misc
*.log
*.tmp
RELEASE-*.md
